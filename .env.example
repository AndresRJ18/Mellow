# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Local: http://localhost:8000/auth/callback
# Producción: https://mellow.lat/auth/callback
SPOTIFY_REDIRECT_URI=http://localhost:8000/auth/callback

# Supabase (backend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=           # service_role key — nunca expongas esto al frontend
SUPABASE_JWT_SECRET=            # Settings > API > JWT Settings

# URLs
FRONTEND_URL=https://mellow.lat

# Vite build-time (frontend)
VITE_API_URL=https://api.mellow.lat
VITE_BACKEND_URL=https://api.mellow.lat
VITE_SPOTIFY_CLIENT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
